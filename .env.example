# ============================================
# Supabase 配置示例（请复制为 .env.local 后填写真实值）
# ============================================

# 从 Supabase Dashboard → Project Settings → API 获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 服务端专用（可选，Demo 阶段可先不填）
# 使用 service_role key 可以绕过 RLS（仅在服务端使用，永远不要暴露到前端）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 从 Google Cloud Console 获取（Places API + Geocoding API 需启用）
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
# 服务端分析 API 优先使用（可与上面相同；不要暴露 service account）
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# 中国大陆开发：Next.js 服务端无法直连 maps.googleapis.com 时需配置代理
# GOOGLE_MAPS_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 无法访问 Google 时本地开发可启用 mock 数据（生产环境勿开启）
# GOOGLE_MAPS_MOCK=true

# DATABASE_URL=   # 如果未来直接用 pg 驱动可使用

# ============================================
# Freemium 用量追踪（登录用户）
# 在 Supabase SQL Editor 运行 doc/supabase-analysis-usage.sql
# ============================================
